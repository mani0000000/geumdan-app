# ─── Supabase (required for client-side data fetching) ──────────────────────
# Get these from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Supabase Service Key (batch scripts only — NEVER expose to client) ──────
# Get this from: https://supabase.com → Project Settings → API → service_role key
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ─── 공공데이터포털 API (batch scripts) ──────────────────────────────────────
# Register at: https://data.go.kr and get an API key
# Required for: fetch-realstate.mjs, fetch-pharmacies.mjs, fetch-emergency.mjs
DATA_GO_KR_API_KEY=your-data-go-kr-api-key-here

# ─── 국토교통부 실거래가 OPEN API (realestate batch) ─────────────────────────
# data.go.kr 인증키 (DATA_GO_KR_API_KEY 와 동일 키로 사용 가능)
# Required for: scripts/fetch_realestate.ts, /api/cron/realestate
MOLIT_API_KEY=your-molit-api-key-here

# ─── Vercel Cron 보호 (realestate batch) ─────────────────────────────────────
# Vercel Cron 자동 호출 / 어드민 수동 실행 시 Authorization: Bearer 검증
# 임의의 무작위 문자열 (예: openssl rand -hex 32)
CRON_SECRET=your-cron-secret-here

# ─── Naver Search API (batch scripts) ────────────────────────────────────────
# Register at: https://developers.naver.com and create an application
# Required for: fetch-news.mjs
NAVER_CLIENT_ID=your-naver-client-id-here
NAVER_CLIENT_SECRET=your-naver-client-secret-here

# ─── 오피넷(OPINET) 주유소 가격 API ───────────────────────────────────────────
# Register at: https://www.opinet.co.kr → 정보마당 → OpenAPI 신청
# Required for: 홈 "주유소 가격" 위젯 (app/api/gas/route.ts)
# 미설정 시 코드 폴백 키로 동작하나, 운영(Vercel)에는 반드시 별도 등록할 것
OPINET_API_KEY=F260518486
