# ─── Supabase (required for client-side data fetching) ──────────────────────
# Get these from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Supabase Service Key (batch scripts only — NEVER expose to client) ──────
# Get this from: https://supabase.com → Project Settings → API → service_role key
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ─── 공공데이터포털 API (batch scripts) ──────────────────────────────────────
# Register at: https://data.go.kr and get an API key
# Required for: fetch-realstate.mjs, fetch-pharmacies.mjs, fetch-emergency.mjs
DATA_GO_KR_API_KEY=your-data-go-kr-api-key-here

# ─── Naver Search API (batch scripts) ────────────────────────────────────────
# Register at: https://developers.naver.com and create an application
# Required for: fetch-news.mjs
NAVER_CLIENT_ID=your-naver-client-id-here
NAVER_CLIENT_SECRET=your-naver-client-secret-here
